# ================================================================
# .env.example - copie pra .env.local e preencha. NUNCA commitar .env.local.
# Gera secrets fortes com:  openssl rand -hex 32
# (PowerShell: [Convert]::ToHexString((1..32 | %{Get-Random -Max 256})))
# ================================================================

# Postgres
DATABASE_URL=postgres://user:pass@host:5432/dbname

# NextAuth (obrigatório - min 32 chars)
AUTH_SECRET=
AUTH_URL=https://garciasadler.vercel.app

# Webhook Evolution (obrigatório em produção - fail-closed)
WEBHOOK_SECRET=

# Cron Vercel (obrigatório em produção - fail-closed)
CRON_SECRET=

# Criptografia de credenciais de integrações (Exato etc) - min 32 chars
# Gere com: openssl rand -hex 32
INTEGRATION_ENCRYPTION_KEY=

# Evolution API
EVOLUTION_API_URL=https://your-evolution-host.example.com
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=

# OpenAI (opcional, só usado quando AI ligada)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# API de produtos (opcional - sem isso, modo mock)
PRODUTOS_API_URL=
PRODUTOS_API_KEY=

# Pusher (opcional - realtime)
PUSHER_APP_ID=
PUSHER_SECRET=
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=

# Registro público - default OFF.
# Setar "true" só pra criar workspaces adicionais; volte pra false em seguida.
ENABLE_PUBLIC_REGISTRATION=false

# Seed (só usados ao rodar npm run db:seed)
SEED_OWNER_EMAIL=
SEED_OWNER_NAME=
SEED_OWNER_PASSWORD=
SEED_WORKSPACE_NAME=Garcia Sadler
SEED_WORKSPACE_SLUG=garcia-sadler

# Rotação de senha (npm run db:rotate-password)
ROTATE_EMAIL=
ROTATE_NEW_PASSWORD=
